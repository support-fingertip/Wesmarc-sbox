<apex:page controller="CustomerCaseController" showHeader="false" sidebar="false" standardStylesheets="false" applyBodyTag="false" applyHtmlTag="true" docType="html-5.0" cache="false">
    <html>
    <head>
        <meta charset="utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1"/>
        <title>Wesmarc Customer Support</title>
        <style>
            * { margin: 0; padding: 0; box-sizing: border-box; }
            body {
                font-family: 'Segoe UI', Roboto, sans-serif;
                background-color: #f5f5f5;
            }
            /* Header */
            .site-header {
                background-color: #000000;
                padding: 1rem 2rem;
                display: flex;
                align-items: center;
            }
            .header-logo { height: 50px; margin-right: 1rem; }
            .header-title { color: #ffffff; font-size: 1.5rem; font-weight: 600; }
            /* Body */
            .site-body {
                max-width: 700px;
                margin: 2rem auto;
                padding: 0 1rem;
            }
            .form-card {
                background: #ffffff;
                border-radius: 8px;
                box-shadow: 0 2px 12px rgba(0,0,0,0.08);
                padding: 2rem;
            }
            .form-heading { font-size: 1.5rem; font-weight: 600; color: #1a237e; margin-bottom: 0.25rem; }
            .form-subheading { color: #666; font-size: 0.95rem; margin-bottom: 0.5rem; }
            .form-divider { border: none; border-top: 2px solid #1a237e; margin-bottom: 1.5rem; }
            /* Form fields */
            .form-group { margin-bottom: 1.25rem; }
            .form-group label {
                display: block;
                font-weight: 500;
                margin-bottom: 0.35rem;
                color: #333;
                font-size: 0.95rem;
            }
            .form-group label .required { color: #e53935; }
            .form-group input,
            .form-group textarea {
                width: 100%;
                padding: 0.65rem 0.75rem;
                border: 1px solid #ccc;
                border-radius: 4px;
                font-size: 1rem;
                font-family: inherit;
                transition: border-color 0.2s;
            }
            .form-group input:focus,
            .form-group textarea:focus {
                outline: none;
                border-color: #1a237e;
                box-shadow: 0 0 0 2px rgba(26,35,126,0.15);
            }
            .form-group textarea { resize: vertical; min-height: 80px; }
            /* Button */
            .btn-submit {
                background-color: #1a237e;
                color: #fff;
                border: none;
                padding: 0.75rem 2rem;
                font-size: 1rem;
                border-radius: 4px;
                cursor: pointer;
                font-weight: 500;
                transition: background-color 0.2s;
            }
            .btn-submit:hover { background-color: #0d1557; }
            /* Error */
            .error-msg { color: #e53935; font-size: 0.9rem; margin-bottom: 1rem; }
            /* Success */
            .success-card {
                background: #fff;
                border-radius: 8px;
                box-shadow: 0 2px 12px rgba(0,0,0,0.08);
                padding: 3rem 2rem;
                text-align: center;
            }
            .success-icon { font-size: 4rem; color: #4caf50; margin-bottom: 1rem; }
            .success-heading { font-size: 2rem; font-weight: 600; color: #1a237e; margin-bottom: 0.5rem; }
            .success-msg { color: #555; font-size: 1.1rem; margin-bottom: 1rem; line-height: 1.5; }
            .success-ref { color: #333; font-size: 1rem; margin-bottom: 1.5rem; }
            /* Footer */
            .site-footer {
                background-color: #000000;
                padding: 1rem 2rem;
                margin-top: 3rem;
                text-align: right;
            }
            .footer-logo { height: 25px; }
        </style>
    </head>
    <body>
        <!-- Header -->
        <div class="site-header">
            <apex:image url="{!URLFOR($Resource.WesmarcLogo)}" styleClass="header-logo" alt="Wesmarc"/>
            <span class="header-title">Wesmarc Customer Support</span>
        </div>

        <!-- Main Content -->
        <div class="site-body">
            <apex:form >
                <!-- Form View -->
                <apex:outputPanel rendered="{!NOT(isSubmitted)}">
                    <div class="form-card">
                        <h2 class="form-heading">Report an Issue</h2>
                        <p class="form-subheading">Please fill in the details below and we will get back to you shortly.</p>
                        <hr class="form-divider"/>

                        <apex:outputPanel rendered="{!errorMessage != ''}">
                            <p class="error-msg">{!errorMessage}</p>
                        </apex:outputPanel>

                        <div class="form-group">
                            <label>Name <span class="required">*</span></label>
                            <apex:inputText value="{!customerName}" html-placeholder="Enter your full name"/>
                        </div>

                        <div class="form-group">
                            <label>Mobile Number <span class="required">*</span></label>
                            <apex:inputText value="{!mobileNumber}" html-placeholder="Enter 10-digit mobile number"/>
                        </div>

                        <div class="form-group">
                            <label>Address <span class="required">*</span></label>
                            <apex:inputTextarea value="{!address}" html-placeholder="Enter your complete address"/>
                        </div>

                        <div class="form-group">
                            <label>Issue Details <span class="required">*</span></label>
                            <apex:inputTextarea value="{!issueDetails}" html-placeholder="Describe the issue you are facing"/>
                        </div>

                        <apex:commandButton action="{!submitCase}" value="Submit" styleClass="btn-submit"/>
                    </div>
                </apex:outputPanel>

                <!-- Success View -->
                <apex:outputPanel rendered="{!isSubmitted}">
                    <div class="success-card">
                        <div class="success-icon">&#10004;</div>
                        <h2 class="success-heading">Thank You!</h2>
                        <p class="success-msg">Your issue has been submitted successfully. Our Sales Support Team will review and get back to you shortly.</p>
                        <p class="success-ref">Case Number: <strong>{!caseNumber}</strong></p>
                        <apex:commandButton action="{!resetForm}" value="Submit Another Issue" styleClass="btn-submit"/>
                    </div>
                </apex:outputPanel>
            </apex:form>
        </div>

        <!-- Footer -->
        <div class="site-footer">
            <apex:image url="{!URLFOR($Resource.WesmarcLogo)}" styleClass="footer-logo" alt="Wesmarc"/>
        </div>
    </body>
    </html>
</apex:page>